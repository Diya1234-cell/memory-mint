rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSpaceMember(spaceId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /spaces/{spaceId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members;
      allow read: if isSpaceMember(spaceId);
      allow update, delete: if isSpaceMember(spaceId);

      match /letterStates/{userId} {
        allow read, write: if isSpaceMember(spaceId) && request.auth.uid == userId;
      }
    }

    match /memories/{memoryId} {
      allow create: if isSpaceMember(request.resource.data.spaceId)
        && request.resource.data.ownerId == request.auth.uid;
      allow read: if isSpaceMember(resource.data.spaceId);
      allow update, delete: if isSpaceMember(resource.data.spaceId)
        && resource.data.ownerId == request.auth.uid;
    }
  }
}
