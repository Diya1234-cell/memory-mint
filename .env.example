# Copy this file to .env.local, replace every value with your own Firebase and
# Gemini credentials, then restart npm run dev.

# ─── Firebase Web SDK ────────────────────────────────────────────────────────
# (Firebase Console > Project settings > Your apps > Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Required for Cloud Storage features; not required for login/signup.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Gemini AI ───────────────────────────────────────────────────────────────
# Optional. Used for AI-powered features (StoryBook, Pulse, Captions, etc.).
# Get a free API key from https://aistudio.google.com/apikey
# NEXT_PUBLIC_GEMINI_API_KEY=
