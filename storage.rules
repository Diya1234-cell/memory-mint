rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSpaceMember(spaceId) {
      return request.auth != null
        && request.auth.uid in firestore.get(/databases/(default)/documents/spaces/$(spaceId)).data.members;
    }

    match /spaces/{spaceId}/{allPaths=**} {
      allow read, write: if isSpaceMember(spaceId);
    }
  }
}
